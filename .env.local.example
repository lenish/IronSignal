ANTHROPIC_API_KEY=op://Server-Secrets/anthropic-api/credential

TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Economic Indicators (FRED API - free signup at fred.stlouisfed.org)
FRED_API_KEY=your_fred_api_key_here

# LME Warehouse Inventory (Nasdaq Data Link - PAID subscription required)
# Sign up at: https://data.nasdaq.com
NASDAQ_DATA_LINK_KEY=

# Vercel Cron Secret (used to authenticate cron job requests)
CRON_SECRET=your-secret-here
